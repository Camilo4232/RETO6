      <div class="editor flex lazy-editor" style=""><pre tabindex="0" class="lazy-virtualized" style="font-size: 14px; line-height: 19px;"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark colab-dark colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk8">#&nbsp;================================================</span><span class="mtk8">============</span></span><br><span><span class="mtk8">#&nbsp;INTERFAZ&nbsp;GRADIO&nbsp;PARA&nbsp;DEMO&nbsp;EN&nbsp;VIVO</span></span><br><span><span class="mtk8">#&nbsp;================================================</span><span class="mtk8">============</span></span><br><span><span class="mtk8">#&nbsp;Agregar&nbsp;esta&nbsp;celda&nbsp;al&nbsp;final&nbsp;del&nbsp;notebook&nbsp;reto6_s</span><span class="mtk8">entiment_analysis.ipynb</span></span><br><span><span class="mtk8">#&nbsp;Requiere&nbsp;haber&nbsp;ejecutado&nbsp;las&nbsp;celdas&nbsp;anteriores&nbsp;(</span><span class="mtk8">modelo&nbsp;entrenado&nbsp;en&nbsp;OUTPUT_DIR)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Instalación&nbsp;de&nbsp;Gradio&nbsp;(solo&nbsp;necesario&nbsp;una&nbsp;vez)</span></span><br><span><span class="mtk19">!</span><span class="mtk1">pip&nbsp;install&nbsp;-q&nbsp;gradio==</span><span class="mtk6">4.44.0</span></span><br><span><span></span></span><br><span><span class="mtk20">import</span><span class="mtk1">&nbsp;gradio&nbsp;</span><span class="mtk20">as</span><span class="mtk1">&nbsp;gr</span></span><br><span><span class="mtk20">import</span><span class="mtk1">&nbsp;torch</span></span><br><span><span class="mtk20">import</span><span class="mtk1">&nbsp;numpy&nbsp;</span><span class="mtk20">as</span><span class="mtk1">&nbsp;np</span></span><br><span><span class="mtk20">from</span><span class="mtk1">&nbsp;transformers&nbsp;</span><span class="mtk20">import</span><span class="mtk1">&nbsp;pipeline</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Cargar&nbsp;el&nbsp;modelo&nbsp;entrenado&nbsp;(usa&nbsp;la&nbsp;misma&nbsp;variabl</span><span class="mtk8">e&nbsp;OUTPUT_DIR&nbsp;del&nbsp;notebook)</span></span><br><span><span class="mtk1">clasificador_demo&nbsp;=&nbsp;pipeline</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"text-classification"</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;model=OUTPUT_DIR</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;tokenizer=OUTPUT_DIR</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;device=</span><span class="mtk6">0</span><span class="mtk1">&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;torch.cuda.is_available</span><span class="mtk14">()</span><span class="mtk1">&nbsp;</span><span class="mtk20">else</span><span class="mtk1">&nbsp;</span><span class="mtk6">-1</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;top_k=</span><span class="mtk9">None</span><span class="mtk14">,</span></span><br><span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">LABEL_NAMES_DEMO&nbsp;=&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"1★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"2★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"3★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"4★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"5★"</span><span class="mtk14">]</span></span><br><span><span></span></span><br><span><span class="mtk10">def</span><span class="mtk1">&nbsp;</span><span class="mtk17">recomendar_accion_demo</span><span class="mtk1">(</span><span class="mtk4">estrellas</span><span class="mtk1">:&nbsp;</span><span class="mtk4">int</span><span class="mtk1">)&nbsp;-&gt;&nbsp;</span><span class="mtk16">str</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;estrellas&nbsp;&lt;=&nbsp;</span><span class="mtk6">2</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk5">"🚨&nbsp;**URGENTE**&nbsp;—&nbsp;Contactar&nbsp;al&nbsp;cliente&nbsp;en&nbsp;menos&nbsp;de&nbsp;</span><span class="mtk5">24&nbsp;horas.&nbsp;Posible&nbsp;riesgo&nbsp;de&nbsp;churn&nbsp;o&nbsp;reseña&nbsp;pública&nbsp;</span><span class="mtk5">negativa."</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;estrellas&nbsp;==&nbsp;</span><span class="mtk6">3</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk5">"⚠️&nbsp;**Reseña&nbsp;neutra**&nbsp;—&nbsp;Solicitar&nbsp;feedback&nbsp;</span><span class="mtk5">específico&nbsp;para&nbsp;entender&nbsp;qué&nbsp;faltó."</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk5">"✅&nbsp;**Reseña&nbsp;positiva**&nbsp;—&nbsp;Agradecer&nbsp;al&nbsp;cliente&nbsp;y,&nbsp;</span><span class="mtk5">si&nbsp;aplica,&nbsp;invitar&nbsp;a&nbsp;reseñar&nbsp;en&nbsp;marketplace&nbsp;</span><span class="mtk5">público."</span></span><br><span><span></span></span><br><span><span class="mtk10">def</span><span class="mtk1">&nbsp;</span><span class="mtk17">predecir_interfaz</span><span class="mtk1">(</span><span class="mtk4">texto</span><span class="mtk1">)</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"""Función&nbsp;que&nbsp;Gradio&nbsp;llama&nbsp;cada&nbsp;vez&nbsp;que&nbsp;el&nbsp;</span><span class="mtk5">usuario&nbsp;aprieta&nbsp;'Predecir'."""</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;</span><span class="mtk19">not</span><span class="mtk1">&nbsp;texto&nbsp;</span><span class="mtk19">or</span><span class="mtk1">&nbsp;</span><span class="mtk19">not</span><span class="mtk1">&nbsp;texto.strip</span><span class="mtk14">():</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"⚠️&nbsp;Por&nbsp;favor&nbsp;escribe&nbsp;una&nbsp;reseña."</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">{},</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">""</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;Inferencia</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;resultados&nbsp;=&nbsp;clasificador_demo</span><span class="mtk14">(</span><span class="mtk1">texto</span><span class="mtk14">)[</span><span class="mtk6">0</span><span class="mtk14">]</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;probs&nbsp;=&nbsp;</span><span class="mtk14">{</span><span class="mtk1">r</span><span class="mtk14">[</span><span class="mtk5">"label"</span><span class="mtk14">]:</span><span class="mtk1">&nbsp;r</span><span class="mtk14">[</span><span class="mtk5">"score"</span><span class="mtk14">]</span><span class="mtk1">&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;r&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;resultados</span><span class="mtk14">}</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;probs_ordenado&nbsp;=&nbsp;</span><span class="mtk14">{</span><span class="mtk1">k</span><span class="mtk14">:</span><span class="mtk1">&nbsp;probs</span><span class="mtk14">[</span><span class="mtk1">k</span><span class="mtk14">]</span><span class="mtk1">&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;k&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;LABEL_NAMES_DEMO&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;k&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;probs</span><span class="mtk14">}</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;pred_label&nbsp;=&nbsp;</span><span class="mtk17">max</span><span class="mtk14">(</span><span class="mtk1">probs_ordenado</span><span class="mtk14">,</span><span class="mtk1">&nbsp;key=probs_ordenado.get</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;pred_estrellas&nbsp;=&nbsp;LABEL_NAMES_DEMO.index</span><span class="mtk14">(</span><span class="mtk1">pred_label</span><span class="mtk14">)</span><span class="mtk1">&nbsp;+&nbsp;</span><span class="mtk6">1</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;confianza&nbsp;=&nbsp;probs_ordenado</span><span class="mtk14">[</span><span class="mtk1">pred_label</span><span class="mtk14">]</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk8">#&nbsp;Resultado&nbsp;principal&nbsp;con&nbsp;emoji&nbsp;visual</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;estrellas_visuales&nbsp;=&nbsp;</span><span class="mtk5">"⭐"</span><span class="mtk1">&nbsp;*&nbsp;pred_estrellas&nbsp;+&nbsp;</span><span class="mtk5">"☆"</span><span class="mtk1">&nbsp;*&nbsp;</span><span class="mtk14">(</span><span class="mtk6">5</span><span class="mtk1">&nbsp;-&nbsp;pred_estrellas</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;resultado_principal&nbsp;=&nbsp;</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk10">f</span><span class="mtk5">"##&nbsp;</span><span class="mtk14">{</span><span class="mtk1">estrellas_visuales</span><span class="mtk14">}</span><span class="mtk5">&nbsp;&nbsp;(</span><span class="mtk14">{</span><span class="mtk1">pred_estrellas</span><span class="mtk14">}</span><span class="mtk5">&nbsp;estrellas)\n\n"</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk10">f</span><span class="mtk5">"**Confianza:**&nbsp;</span><span class="mtk14">{</span><span class="mtk1">confianza*</span><span class="mtk6">100:.1f</span><span class="mtk14">}</span><span class="mtk5">%"</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;accion&nbsp;=&nbsp;recomendar_accion_demo</span><span class="mtk14">(</span><span class="mtk1">pred_estrellas</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;resultado_principal</span><span class="mtk14">,</span><span class="mtk1">&nbsp;probs_ordenado</span><span class="mtk14">,</span><span class="mtk1">&nbsp;accion</span></span><br><span><span></span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Ejemplos&nbsp;predefinidos&nbsp;para&nbsp;la&nbsp;presentación&nbsp;</span><span class="mtk8">(botones&nbsp;de&nbsp;un&nbsp;solo&nbsp;click)</span></span><br><span><span class="mtk1">ejemplos_demo&nbsp;=&nbsp;</span><span class="mtk14">[</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"Llegó&nbsp;rápido&nbsp;y&nbsp;la&nbsp;calidad&nbsp;es&nbsp;excelente,&nbsp;lo&nbsp;</span><span class="mtk5">recomiendo&nbsp;totalmente."</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"El&nbsp;producto&nbsp;no&nbsp;enciende&nbsp;y&nbsp;el&nbsp;vendedor&nbsp;no&nbsp;responde&nbsp;</span><span class="mtk5">mis&nbsp;mensajes.&nbsp;Pésima&nbsp;experiencia."</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"Cumple&nbsp;lo&nbsp;básico&nbsp;pero&nbsp;esperaba&nbsp;más&nbsp;por&nbsp;el&nbsp;precio&nbsp;</span><span class="mtk5">que&nbsp;pagué."</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"ESTAFA&nbsp;TOTAL.&nbsp;Pagué&nbsp;por&nbsp;una&nbsp;plancha&nbsp;y&nbsp;me&nbsp;llegó&nbsp;</span><span class="mtk5">una&nbsp;caja&nbsp;vacía."</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"Buen&nbsp;producto,&nbsp;llegó&nbsp;a&nbsp;tiempo.&nbsp;Las&nbsp;instrucciones&nbsp;</span><span class="mtk5">están&nbsp;solo&nbsp;en&nbsp;inglés&nbsp;pero&nbsp;igual&nbsp;recomendado."</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"Hace&nbsp;ruido&nbsp;raro&nbsp;al&nbsp;usarlo&nbsp;más&nbsp;de&nbsp;10&nbsp;minutos,&nbsp;no&nbsp;</span><span class="mtk5">sé&nbsp;si&nbsp;es&nbsp;defecto&nbsp;o&nbsp;normal."</span><span class="mtk14">],</span></span><br><span><span class="mtk14">]</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Construcción&nbsp;de&nbsp;la&nbsp;interfaz&nbsp;Gradio</span></span><br><span><span class="mtk20">with</span><span class="mtk1">&nbsp;gr.Blocks</span><span class="mtk14">(</span><span class="mtk1">theme=gr.themes.Soft</span><span class="mtk14">(</span><span class="mtk1">primary_hue=</span><span class="mtk5">"blue"</span><span class="mtk14">),</span><span class="mtk1">&nbsp;title=</span><span class="mtk5">"Demo&nbsp;BETO&nbsp;—&nbsp;Reto&nbsp;6"</span><span class="mtk14">)</span><span class="mtk1">&nbsp;</span><span class="mtk20">as</span><span class="mtk1">&nbsp;demo</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;gr.Markdown</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"""</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;#&nbsp;🎯&nbsp;Análisis&nbsp;de&nbsp;Sentimiento&nbsp;de&nbsp;Reseñas</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;###&nbsp;Reto&nbsp;6&nbsp;—&nbsp;Universidad&nbsp;de&nbsp;Boyacá&nbsp;—&nbsp;IA&nbsp;</span><span class="mtk1">Unidad&nbsp;4</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;**Modelo:**&nbsp;BETO&nbsp;(BERT&nbsp;en&nbsp;español)&nbsp;</span><span class="mtk1">fine-tuned&nbsp;sobre&nbsp;Amazon&nbsp;Reviews&nbsp;ES</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;**Equipo:**&nbsp;Camilo&nbsp;Andres&nbsp;Ortiz&nbsp;Gonzalez&nbsp;·&nbsp;</span><span class="mtk1">Omar&nbsp;Elian&nbsp;Martinez&nbsp;Perez</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Escribe&nbsp;una&nbsp;reseña&nbsp;en&nbsp;español&nbsp;y&nbsp;el&nbsp;modelo&nbsp;</span><span class="mtk1">predecirá&nbsp;cuántas&nbsp;estrellas&nbsp;le&nbsp;habría&nbsp;dado&nbsp;el&nbsp;</span><span class="mtk1">cliente.</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"""</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">with</span><span class="mtk1">&nbsp;gr.Row</span><span class="mtk14">():</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">with</span><span class="mtk1">&nbsp;gr.Column</span><span class="mtk14">(</span><span class="mtk1">scale=</span><span class="mtk6">1</span><span class="mtk14">):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;entrada&nbsp;=&nbsp;gr.Textbox</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;label=</span><span class="mtk5">"📝&nbsp;Reseña&nbsp;del&nbsp;cliente"</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;placeholder=</span><span class="mtk5">"Escribe&nbsp;aquí&nbsp;una&nbsp;reseña&nbsp;en&nbsp;español..."</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;lines=</span><span class="mtk6">5</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;boton&nbsp;=&nbsp;gr.Button</span><span class="mtk14">(</span><span class="mtk5">"🔍&nbsp;Predecir&nbsp;sentimiento"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;variant=</span><span class="mtk5">"primary"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;size=</span><span class="mtk5">"lg"</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;gr.Examples</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;examples=ejemplos_demo</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;inputs=entrada</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;label=</span><span class="mtk5">"💡&nbsp;Ejemplos&nbsp;para&nbsp;probar&nbsp;(clic&nbsp;para&nbsp;</span><span class="mtk5">autocompletar)"</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">with</span><span class="mtk1">&nbsp;gr.Column</span><span class="mtk14">(</span><span class="mtk1">scale=</span><span class="mtk6">1</span><span class="mtk14">):</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;salida_principal&nbsp;=&nbsp;gr.Markdown</span><span class="mtk14">(</span><span class="mtk1">label=</span><span class="mtk5">"</span><span class="mtk1">Predicción</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;salida_distribucion&nbsp;=&nbsp;gr.Label</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;label=</span><span class="mtk5">"📊&nbsp;Distribución&nbsp;de&nbsp;probabilidad"</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;num_top_classes=</span><span class="mtk6">5</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;salida_accion&nbsp;=&nbsp;gr.Markdown</span><span class="mtk14">(</span><span class="mtk1">label=</span><span class="mtk5">"</span><span class="mtk1">🎯&nbsp;Acción&nbsp;recomendada</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;boton.click</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;fn=predecir_interfaz</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;inputs=entrada</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;outputs=</span><span class="mtk14">[</span><span class="mtk1">salida_principal</span><span class="mtk14">,</span><span class="mtk1">&nbsp;salida_distribucion</span><span class="mtk14">,</span><span class="mtk1">&nbsp;salida_accion</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;gr.Markdown</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"""</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;---</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;ℹ️&nbsp;**Cómo&nbsp;funciona:**&nbsp;El&nbsp;modelo&nbsp;lee&nbsp;tu&nbsp;</span><span class="mtk1">texto,&nbsp;lo&nbsp;convierte&nbsp;en&nbsp;tokens&nbsp;y&nbsp;a&nbsp;través&nbsp;de&nbsp;12&nbsp;</span><span class="mtk1">capas</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Transformer&nbsp;estima&nbsp;la&nbsp;probabilidad&nbsp;de&nbsp;que&nbsp;</span><span class="mtk1">la&nbsp;reseña&nbsp;corresponda&nbsp;a&nbsp;cada&nbsp;nivel&nbsp;de&nbsp;estrellas&nbsp;(1&nbsp;</span><span class="mtk1">a&nbsp;5).</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;🎓&nbsp;*Notebook&nbsp;completo&nbsp;y&nbsp;código&nbsp;fuente:&nbsp;ver&nbsp;</span><span class="mtk1">el&nbsp;repositorio&nbsp;del&nbsp;equipo.*</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"""</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Lanzar&nbsp;interfaz</span></span><br><span><span class="mtk8">#&nbsp;share=True&nbsp;genera&nbsp;una&nbsp;URL&nbsp;pública&nbsp;temporal&nbsp;</span><span class="mtk8">(válida&nbsp;~72&nbsp;horas)&nbsp;ideal&nbsp;para&nbsp;demo&nbsp;en&nbsp;clase</span></span><br><span><span class="mtk1">demo.launch</span><span class="mtk14">(</span><span class="mtk1">share=</span><span class="mtk9">True</span><span class="mtk14">,</span><span class="mtk1">&nbsp;debug=</span><span class="mtk9">False</span><span class="mtk14">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$656697830$-->Empieza a programar o a <span tabindex="0" role="button" class="link">crear código</span> con IA.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
