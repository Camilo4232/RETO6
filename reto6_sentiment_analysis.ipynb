k1">.legend</span><span class="mtk14">()</span></span><br><span><span class="mtk1">axes</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">]</span><span class="mtk1">.set_xlim</span><span class="mtk14">(</span><span class="mtk6">0</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">300</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Longitud&nbsp;por&nbsp;clase:&nbsp;¿las&nbsp;reseñas&nbsp;negativas&nbsp;son&nbsp;</span><span class="mtk8">más&nbsp;largas?</span></span><br><span><span class="mtk1">sns.boxplot</span><span class="mtk14">(</span><span class="mtk1">data=df_train</span><span class="mtk14">,</span><span class="mtk1">&nbsp;x=</span><span class="mtk5">"label"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;y=</span><span class="mtk5">"n_palabras"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;ax=axes</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;palette=sns.color_palette</span><span class="mtk14">(</span><span class="mtk5">"RdYlGn"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">5</span><span class="mtk14">),</span><span class="mtk1">&nbsp;showfliers=</span><span class="mtk9">False</span><span class="mtk14">)</span></span><br><span><span class="mtk1">axes</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]</span><span class="mtk1">.set_title</span><span class="mtk14">(</span><span class="mtk5">"Longitud&nbsp;(palabras)&nbsp;por&nbsp;clase"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">axes</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]</span><span class="mtk1">.set_xlabel</span><span class="mtk14">(</span><span class="mtk5">"Estrellas&nbsp;(0=1★,&nbsp;4=5★)"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">axes</span><span class="mtk14">[</span><span class="mtk6">1</span><span class="mtk14">]</span><span class="mtk1">.set_ylabel</span><span class="mtk14">(</span><span class="mtk5">"nº&nbsp;palabras"</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">plt.tight_layout</span><span class="mtk14">()</span></span><br><span><span class="mtk1">plt.show</span><span class="mtk14">()</span></span><br><span><span></span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk1">df_train</span><span class="mtk14">[[</span><span class="mtk5">"n_palabras"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"n_chars"</span><span class="mtk14">]]</span><span class="mtk1">.describe</span><span class="mtk14">()</span><span class="mtk1">.</span><span class="mtk17">round</span><span class="mtk14">(</span><span class="mtk6">1</span><span class="mtk14">))</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$656697830$-->Empieza a programar o a <span tabindex="0" role="button" class="link">crear código</span> con IA.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
