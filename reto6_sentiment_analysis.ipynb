n><br><span><span class="mtk8">#&nbsp;El&nbsp;Trainer&nbsp;espera&nbsp;la&nbsp;columna&nbsp;'labels'&nbsp;(plural)</span></span><br><span><span class="mtk1">ds_train&nbsp;=&nbsp;ds_train.rename_column</span><span class="mtk14">(</span><span class="mtk5">"label"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"labels"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ds_val&nbsp;=&nbsp;ds_val.rename_column</span><span class="mtk14">(</span><span class="mtk5">"label"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"labels"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">ds_test&nbsp;=&nbsp;ds_test.rename_column</span><span class="mtk14">(</span><span class="mtk5">"label"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"labels"</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">ds_train.set_format</span><span class="mtk14">(</span><span class="mtk5">"torch"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;columns=</span><span class="mtk14">[</span><span class="mtk5">"input_ids"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"attention_mask"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"labels"</span><span class="mtk14">])</span></span><br><span><span class="mtk1">ds_val.set_format</span><span class="mtk14">(</span><span class="mtk5">"torch"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;columns=</span><span class="mtk14">[</span><span class="mtk5">"input_ids"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"attention_mask"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"labels"</span><span class="mtk14">])</span></span><br><span><span class="mtk1">ds_test.set_format</span><span class="mtk14">(</span><span class="mtk5">"torch"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;columns=</span><span class="mtk14">[</span><span class="mtk5">"input_ids"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"attention_mask"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"labels"</span><span class="mtk14">])</span></span><br><span><span></span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk5">"Tokenización&nbsp;lista."</span><span class="mtk14">)</span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"Primer&nbsp;ejemplo&nbsp;tokenizado:&nbsp;input_ids&nbsp;shape&nbsp;=&nbsp;</span><span class="mtk14">{</span><span class="mtk1">ds_train</span><span class="mtk14">[</span><span class="mtk6">0</span><span class="mtk14">][</span><span class="mtk5">'input_ids'</span><span class="mtk14">]</span><span class="mtk1">.shape</span><span class="mtk14">}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$656697830$-->Empieza a programar o a <span tabindex="0" role="button" class="link">crear código</span> con IA.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
