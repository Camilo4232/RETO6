      <div class="editor flex lazy-editor" style=""><pre tabindex="0" class="lazy-virtualized" style="font-size: 14px; line-height: 19px;"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark colab-dark colab-dark colab-dark colab-dark colab-dark colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk8">#&nbsp;Modelo:&nbsp;cargamos&nbsp;BETO&nbsp;con&nbsp;cabezal&nbsp;de&nbsp;</span><span class="mtk8">clasificación&nbsp;de&nbsp;5&nbsp;clases</span></span><br><span><span class="mtk1">NUM_LABELS&nbsp;=&nbsp;</span><span class="mtk6">5</span></span><br><span><span class="mtk1">LABEL_NAMES&nbsp;=&nbsp;</span><span class="mtk14">[</span><span class="mtk5">"1★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"2★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"3★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"4★"</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">"5★"</span><span class="mtk14">]</span></span><br><span><span class="mtk1">id2label&nbsp;=&nbsp;</span><span class="mtk14">{</span><span class="mtk1">i</span><span class="mtk14">:</span><span class="mtk1">&nbsp;name&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;i</span><span class="mtk14">,</span><span class="mtk1">&nbsp;name&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">enumerate</span><span class="mtk14">(</span><span class="mtk1">LABEL_NAMES</span><span class="mtk14">)}</span></span><br><span><span class="mtk1">label2id&nbsp;=&nbsp;</span><span class="mtk14">{</span><span class="mtk1">name</span><span class="mtk14">:</span><span class="mtk1">&nbsp;i&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;i</span><span class="mtk14">,</span><span class="mtk1">&nbsp;name&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;</span><span class="mtk17">enumerate</span><span class="mtk14">(</span><span class="mtk1">LABEL_NAMES</span><span class="mtk14">)}</span></span><br><span><span></span></span><br><span><span class="mtk1">model&nbsp;=&nbsp;AutoModelForSequenceClassification.from_pr</span><span class="mtk1">etrained</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;MODEL_NAME</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;num_labels=NUM_LABELS</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;id2label=id2label</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;label2id=label2id</span><span class="mtk14">,</span></span><br><span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">n_params&nbsp;=&nbsp;</span><span class="mtk17">sum</span><span class="mtk14">(</span><span class="mtk1">p.numel</span><span class="mtk14">()</span><span class="mtk1">&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;p&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;model.parameters</span><span class="mtk14">())</span></span><br><span><span class="mtk1">n_trainable&nbsp;=&nbsp;</span><span class="mtk17">sum</span><span class="mtk14">(</span><span class="mtk1">p.numel</span><span class="mtk14">()</span><span class="mtk1">&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;p&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;model.parameters</span><span class="mtk14">()</span><span class="mtk1">&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;p.requires_grad</span><span class="mtk14">)</span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"Parámetros&nbsp;totales:&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">{</span><span class="mtk1">n_params</span><span class="mtk6">:,</span><span class="mtk14">}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"Parámetros&nbsp;entrenables:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">n_trainable</span><span class="mtk6">:,</span><span class="mtk14">}</span><span class="mtk5">&nbsp;&nbsp;(100%&nbsp;—&nbsp;fine-tuning&nbsp;completo)"</span><span class="mtk14">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$656697830$-->Empieza a programar o a <span tabindex="0" role="button" class="link">crear código</span> con IA.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
