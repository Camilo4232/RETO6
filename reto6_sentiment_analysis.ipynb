k17">max</span><span class="mtk14">(</span><span class="mtk1">probs_ordenado</span><span class="mtk14">,</span><span class="mtk1">&nbsp;key=probs_ordenado.get</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;pred_estrellas&nbsp;=&nbsp;LABEL_NAMES.index</span><span class="mtk14">(</span><span class="mtk1">pred_label</span><span class="mtk14">)</span><span class="mtk1">&nbsp;+&nbsp;</span><span class="mtk6">1</span></span><br><span><span></span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;out&nbsp;=&nbsp;</span><span class="mtk14">{</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"texto"</span><span class="mtk14">:</span><span class="mtk1">&nbsp;texto</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"prediccion_estrellas"</span><span class="mtk14">:</span><span class="mtk1">&nbsp;pred_estrellas</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"confianza"</span><span class="mtk14">:</span><span class="mtk1">&nbsp;probs_ordenado</span><span class="mtk14">[</span><span class="mtk1">pred_label</span><span class="mtk14">],</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"distribucion"</span><span class="mtk14">:</span><span class="mtk1">&nbsp;probs_ordenado</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk5">"accion_recomendada"</span><span class="mtk14">:</span><span class="mtk1">&nbsp;recomendar_accion</span><span class="mtk14">(</span><span class="mtk1">pred_estrellas</span><span class="mtk14">),</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk14">}</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">if</span><span class="mtk1">&nbsp;verboso</span><span class="mtk14">:</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"📝&nbsp;Reseña:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">texto</span><span class="mtk6">!r</span><span class="mtk14">}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"⭐&nbsp;Predicción:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">pred_estrellas</span><span class="mtk14">}</span><span class="mtk5">★&nbsp;&nbsp;(confianza:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">out</span><span class="mtk14">[</span><span class="mtk5">'confianza'</span><span class="mtk14">]</span><span class="mtk1">*</span><span class="mtk6">100:.1f</span><span class="mtk14">}</span><span class="mtk5">%)"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"📊&nbsp;Distribución:"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">for</span><span class="mtk1">&nbsp;k</span><span class="mtk14">,</span><span class="mtk1">&nbsp;v&nbsp;</span><span class="mtk19">in</span><span class="mtk1">&nbsp;probs_ordenado.items</span><span class="mtk14">():</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;bar&nbsp;=&nbsp;</span><span class="mtk5">"█"</span><span class="mtk1">&nbsp;*&nbsp;</span><span class="mtk16">int</span><span class="mtk14">(</span><span class="mtk1">v&nbsp;*&nbsp;</span><span class="mtk6">30</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"&nbsp;&nbsp;&nbsp;</span><span class="mtk14">{</span><span class="mtk1">k</span><span class="mtk14">}</span><span class="mtk5">:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">bar</span><span class="mtk6">:&lt;30</span><span class="mtk14">}</span><span class="mtk5">&nbsp;</span><span class="mtk14">{</span><span class="mtk1">v*</span><span class="mtk6">100:5.1f</span><span class="mtk14">}</span><span class="mtk5">%"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"🎯&nbsp;Acción:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">out</span><span class="mtk14">[</span><span class="mtk5">'accion_recomendada'</span><span class="mtk14">]}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk5">"─"</span><span class="mtk1">&nbsp;*&nbsp;</span><span class="mtk6">80</span><span class="mtk14">)</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;</span><span class="mtk20">return</span><span class="mtk1">&nbsp;out</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$656697830$-->Empieza a programar o a <span tabindex="0" role="button" class="link">crear código</span> con IA.</div></template></colab-read-only-cell-placeholder><