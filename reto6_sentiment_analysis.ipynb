      <div class="editor flex lazy-editor" style=""><pre tabindex="0" class="lazy-virtualized" style="font-size: 14px; line-height: 19px;"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark colab-dark colab-dark colab-dark colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk20">from</span><span class="mtk1">&nbsp;sklearn.feature_extraction.text&nbsp;</span><span class="mtk20">import</span><span class="mtk1">&nbsp;TfidfVectorizer</span></span><br><span><span class="mtk20">from</span><span class="mtk1">&nbsp;sklearn.linear_model&nbsp;</span><span class="mtk20">import</span><span class="mtk1">&nbsp;LogisticRegression</span></span><br><span><span></span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk5">"Entrenando&nbsp;baseline&nbsp;TF-IDF&nbsp;+&nbsp;Logistic&nbsp;Regression.</span><span class="mtk5">.."</span><span class="mtk14">)</span></span><br><span><span class="mtk1">vec&nbsp;=&nbsp;TfidfVectorizer</span><span class="mtk14">(</span><span class="mtk1">max_features=</span><span class="mtk6">20_000</span><span class="mtk14">,</span><span class="mtk1">&nbsp;ngram_range=</span><span class="mtk14">(</span><span class="mtk6">1</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk6">2</span><span class="mtk14">),</span><span class="mtk1">&nbsp;min_df=</span><span class="mtk6">2</span><span class="mtk14">)</span></span><br><span><span class="mtk1">X_train_tfidf&nbsp;=&nbsp;vec.fit_transform</span><span class="mtk14">(</span><span class="mtk1">df_train_s</span><span class="mtk14">[</span><span class="mtk5">"text"</span><span class="mtk14">])</span></span><br><span><span class="mtk1">X_test_tfidf&nbsp;=&nbsp;vec.transform</span><span class="mtk14">(</span><span class="mtk1">df_test_s</span><span class="mtk14">[</span><span class="mtk5">"text"</span><span class="mtk14">])</span></span><br><span><span></span></span><br><span><span class="mtk1">clf&nbsp;=&nbsp;LogisticRegression</span><span class="mtk14">(</span><span class="mtk1">max_iter=</span><span class="mtk6">1000</span><span class="mtk14">,</span><span class="mtk1">&nbsp;n_jobs=</span><span class="mtk6">-1</span><span class="mtk14">,</span><span class="mtk1">&nbsp;random_state=SEED</span><span class="mtk14">)</span></span><br><span><span class="mtk1">clf.fit</span><span class="mtk14">(</span><span class="mtk1">X_train_tfidf</span><span class="mtk14">,</span><span class="mtk1">&nbsp;df_train_s</span><span class="mtk14">[</span><span class="mtk5">"label"</span><span class="mtk14">])</span></span><br><span><span class="mtk1">preds_tfidf&nbsp;=&nbsp;clf.predict</span><span class="mtk14">(</span><span class="mtk1">X_test_tfidf</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk1">acc_tfidf&nbsp;=&nbsp;accuracy_score</span><span class="mtk14">(</span><span class="mtk1">df_test_s</span><span class="mtk14">[</span><span class="mtk5">"label"</span><span class="mtk14">],</span><span class="mtk1">&nbsp;preds_tfidf</span><span class="mtk14">)</span></span><br><span><span class="mtk1">f1_tfidf&nbsp;=&nbsp;f1_score</span><span class="mtk14">(</span><span class="mtk1">df_test_s</span><span class="mtk14">[</span><span class="mtk5">"label"</span><span class="mtk14">],</span><span class="mtk1">&nbsp;preds_tfidf</span><span class="mtk14">,</span><span class="mtk1">&nbsp;average=</span><span class="mtk5">"macro"</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">"\nTF-IDF&nbsp;+&nbsp;LogReg&nbsp;→&nbsp;Accuracy:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">acc_tfidf</span><span class="mtk6">:.4f</span><span class="mtk14">}</span><span class="mtk5">&nbsp;</span><span class="mtk1">|</span><span class="mtk5">&nbsp;F1&nbsp;macro:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">f1_tfidf</span><span class="mtk6">:.4f</span><span class="mtk14">}</span><span class="mtk5">"</span><span class="mtk14">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$656697830$-->Empieza a programar o a <span tabindex="0" role="button" class="link">crear código</span> con IA.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
